<!-- YCB MediumClamp (051_large_clamp used as "cylinder") — standalone MuJoCo MJCF.
     The mesh is scaled 1.75× uniformly to match the original model.urdf.
     Physical properties from YCB dataset (model.urdf) and
     configs/objects/ycb_mujoco_manifest.yaml.
     Load from project root:
       mujoco.MjModel.from_xml_path("owg_robot/assets/ycb/cylinder.xml")
     Paths are relative to this file's directory (owg_robot/assets/ycb/). -->
<mujoco model="ycb_medium_clamp">
  <compiler autolimits="true" angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture name="clamp_tex" type="2d"
             file="../ycb_objects/YcbMediumClamp/texture_map.png"/>
    <material name="clamp_mat" texture="clamp_tex"/>
    <!-- Visual mesh: scaled 1.75× to match URDF scale="1.75 1.75 1.75" -->
    <mesh name="clamp_vis"
          file="../ycb_objects/YcbMediumClamp/textured_reoriented.obj"
          scale="1.75 1.75 1.75"/>
    <!-- Collision mesh: VHACD, same 1.75× scale -->
    <mesh name="clamp_col"
          file="../ycb_objects/YcbMediumClamp/collision_vhacd.obj"
          scale="1.75 1.75 1.75"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="1 1 0.1" pos="0 0 0"/>
    <body name="medium_clamp" pos="0 0 0.08">
      <freejoint/>
      <!-- Visual geometry: rendered, excluded from collision pipeline -->
      <geom name="clamp_visual" type="mesh" mesh="clamp_vis"
            material="clamp_mat" contype="0" conaffinity="0" group="2"/>
      <!-- Collision geometry: mass=0.259 kg (YCB), lower friction for metal -->
      <geom name="clamp_collision" type="mesh" mesh="clamp_col"
            mass="0.259" friction="1.5 0.05 0.01"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
