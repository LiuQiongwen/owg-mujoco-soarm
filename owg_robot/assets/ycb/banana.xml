<!-- YCB Banana (011_banana) — standalone MuJoCo MJCF.
     Physical properties from YCB dataset (model.urdf) and
     configs/objects/ycb_mujoco_manifest.yaml.
     Load from project root:
       mujoco.MjModel.from_xml_path("owg_robot/assets/ycb/banana.xml")
     Paths are relative to this file's directory (owg_robot/assets/ycb/). -->
<mujoco model="ycb_banana">
  <compiler autolimits="true" angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture name="banana_tex" type="2d"
             file="../ycb_objects/YcbBanana/texture_map.png"/>
    <material name="banana_mat" texture="banana_tex"/>
    <!-- Visual mesh: high-poly textured surface, no collision contribution -->
    <mesh name="banana_vis"
          file="../ycb_objects/YcbBanana/textured_simple_reoriented.obj"
          scale="1 1 1"/>
    <!-- Collision mesh: VHACD convex decomposition -->
    <mesh name="banana_col"
          file="../ycb_objects/YcbBanana/collision_vhacd.obj"
          scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="1 1 0.1" pos="0 0 0"/>
    <body name="banana" pos="0 0 0.05">
      <freejoint/>
      <!-- Visual geometry: rendered, excluded from collision pipeline -->
      <geom name="banana_visual" type="mesh" mesh="banana_vis"
            material="banana_mat" contype="0" conaffinity="0" group="2"/>
      <!-- Collision geometry: mass=0.166 kg (YCB), friction tuned for MuJoCo -->
      <geom name="banana_collision" type="mesh" mesh="banana_col"
            mass="0.166" friction="2.0 0.05 0.01"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
