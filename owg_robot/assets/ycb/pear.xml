<!-- YCB Pear (016_pear) — standalone MuJoCo MJCF.
     Physical properties from YCB dataset (model.urdf) and
     configs/objects/ycb_mujoco_manifest.yaml.
     Load from project root:
       mujoco.MjModel.from_xml_path("owg_robot/assets/ycb/pear.xml")
     Paths are relative to this file's directory (owg_robot/assets/ycb/). -->
<mujoco model="ycb_pear">
  <compiler autolimits="true" angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture name="pear_tex" type="2d"
             file="../ycb_objects/YcbPear/texture_map.png"/>
    <material name="pear_mat" texture="pear_tex"/>
    <!-- Visual mesh: high-poly textured surface, no collision contribution -->
    <mesh name="pear_vis"
          file="../ycb_objects/YcbPear/textured_reoriented.obj"
          scale="1 1 1"/>
    <!-- Collision mesh: VHACD convex decomposition -->
    <mesh name="pear_col"
          file="../ycb_objects/YcbPear/collision_vhacd.obj"
          scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="1 1 0.1" pos="0 0 0"/>
    <body name="pear" pos="0 0 0.05">
      <freejoint/>
      <!-- Visual geometry: rendered, excluded from collision pipeline -->
      <geom name="pear_visual" type="mesh" mesh="pear_vis"
            material="pear_mat" contype="0" conaffinity="0" group="2"/>
      <!-- Collision geometry: mass=0.049 kg (YCB), lower friction (smooth skin) -->
      <geom name="pear_collision" type="mesh" mesh="pear_col"
            mass="0.049" friction="1.5 0.05 0.01"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
