<!-- YCB CrackerBox (003_cracker_box) — standalone MuJoCo MJCF.
     Physical properties from YCB dataset (model.urdf) and
     configs/objects/ycb_mujoco_manifest.yaml.
     Load from project root:
       mujoco.MjModel.from_xml_path("owg_robot/assets/ycb/cracker.xml")
     Paths are relative to this file's directory (owg_robot/assets/ycb/). -->
<mujoco model="ycb_cracker_box">
  <compiler autolimits="true" angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture name="cracker_tex" type="2d"
             file="../ycb_objects/YcbCrackerBox/texture_map.png"/>
    <material name="cracker_mat" texture="cracker_tex"/>
    <!-- Visual mesh: high-poly textured surface, no collision contribution -->
    <mesh name="cracker_vis"
          file="../ycb_objects/YcbCrackerBox/textured_simple_reoriented.obj"
          scale="1 1 1"/>
    <!-- Collision mesh: VHACD convex decomposition -->
    <mesh name="cracker_col"
          file="../ycb_objects/YcbCrackerBox/collision_vhacd.obj"
          scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="1 1 0.1" pos="0 0 0"/>
    <body name="cracker_box" pos="0 0 0.10">
      <freejoint/>
      <!-- Visual geometry: rendered, excluded from collision pipeline -->
      <geom name="cracker_visual" type="mesh" mesh="cracker_vis"
            material="cracker_mat" contype="0" conaffinity="0" group="2"/>
      <!-- Collision geometry: mass=0.411 kg (YCB), cardboard box friction -->
      <geom name="cracker_collision" type="mesh" mesh="cracker_col"
            mass="0.411" friction="1.8 0.05 0.01"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
