<!-- YCB MustardBottle (006_mustard_bottle) — standalone MuJoCo MJCF.
     Physical properties from YCB dataset (model.urdf) and
     configs/objects/ycb_mujoco_manifest.yaml.
     Load from project root:
       mujoco.MjModel.from_xml_path("owg_robot/assets/ycb/mustard.xml")
     Paths are relative to this file's directory (owg_robot/assets/ycb/). -->
<mujoco model="ycb_mustard_bottle">
  <compiler autolimits="true" angle="radian"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <asset>
    <texture name="mustard_tex" type="2d"
             file="../ycb_objects/YcbMustardBottle/texture_map.png"/>
    <material name="mustard_mat" texture="mustard_tex"/>
    <!-- Visual mesh: high-poly textured surface, no collision contribution -->
    <mesh name="mustard_vis"
          file="../ycb_objects/YcbMustardBottle/textured_simple_reoriented.obj"
          scale="1 1 1"/>
    <!-- Collision mesh: VHACD convex decomposition -->
    <mesh name="mustard_col"
          file="../ycb_objects/YcbMustardBottle/collision_vhacd.obj"
          scale="1 1 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom type="plane" size="1 1 0.1" pos="0 0 0"/>
    <body name="mustard_bottle" pos="0 0 0.10">
      <freejoint/>
      <!-- Visual geometry: rendered, excluded from collision pipeline -->
      <geom name="mustard_visual" type="mesh" mesh="mustard_vis"
            material="mustard_mat" contype="0" conaffinity="0" group="2"/>
      <!-- Collision geometry: mass=0.603 kg (YCB), standard friction for plastic -->
      <geom name="mustard_collision" type="mesh" mesh="mustard_col"
            mass="0.603" friction="2.0 0.05 0.01"
            contype="1" conaffinity="1"/>
    </body>
  </worldbody>
</mujoco>
